{
  "__inputs": [{ "name": "DS", "label": "Meraki", "type": "datasource", "pluginId": "dubsector-ciscomeraki-datasource" }],
  "__requires": [
    { "type": "grafana",    "id": "grafana",   "name": "Grafana",      "version": "12.0.0" },
    { "type": "datasource", "id": "dubsector-ciscomeraki-datasource", "name": "Cisco Meraki", "version": "1.0.0" },
    { "type": "panel", "id": "stat",  "name": "Stat",  "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "title": "Meraki - Network Events",
  "description": "Network and security event logs.",
  "tags": ["meraki"],
  "editable": true,
  "graphTooltip": 0,
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "refresh": "5m",
  "panels": [
    {
      "id": 1, "type": "row", "title": "Network Events",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }, "panels": []
    },
    {
      "id": 2, "type": "stat", "title": "Total Events",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "dubsector-ciscomeraki-datasource", "uid": "${DS}" },
      "targets": [{
        "refId": "A",
        "queryType": "networkEvents", "networkId": "${network}",
        "productType": "", "deviceSerial": "", "historical": false
      }],
      "options": { "reduceOptions": { "calcs": ["count"], "fields": "/^Event Type$/" }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
      }, "overrides": [] }
    },
    {
      "id": 3, "type": "table", "title": "Event Log",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 14 },
      "datasource": { "type": "dubsector-ciscomeraki-datasource", "uid": "${DS}" },
      "targets": [{
        "refId": "A",
        "queryType": "networkEvents", "networkId": "${network}",
        "productType": "", "deviceSerial": "", "historical": false
      }],
      "options": { "sortBy": [{ "displayName": "occurredAt", "desc": true }] },
      "fieldConfig": { "defaults": { "custom": { "filterable": true } }, "overrides": [] }
    },
    {
      "id": 4, "type": "row", "title": "Security Events",
      "gridPos": { "x": 0, "y": 19, "w": 24, "h": 1 }, "panels": []
    },
    {
      "id": 5, "type": "table", "title": "Security Event Log",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 12 },
      "datasource": { "type": "dubsector-ciscomeraki-datasource", "uid": "${DS}" },
      "targets": [{
        "refId": "A",
        "queryType": "securityEvents", "networkId": "${network}",
        "productType": "", "deviceSerial": "", "historical": false
      }],
      "options": { "sortBy": [{ "displayName": "ts", "desc": true }] },
      "fieldConfig": { "defaults": { "custom": { "filterable": true } }, "overrides": [] }
    }
  ],
  "templating": { "list": [
    { "name": "DS", "type": "datasource", "pluginId": "dubsector-ciscomeraki-datasource", "label": "Data Source", "hide": 0 },
    {
      "name": "network", "type": "query", "label": "Network",
      "datasource": { "type": "dubsector-ciscomeraki-datasource", "uid": "${DS}" },
      "query": "{\"queryType\":\"networkEvents\"}",
      "refresh": 2, "sort": 1, "hide": 0
    }
  ]},
  "annotations": { "list": [] },
  "version": 1,
  "id": null,
  "uid": ""
}
