{
  "name": "dubsector-ciscomeraki-datasource",
  "version": "1.0.2",
  "description": "Grafana datasource plugin for Cisco Meraki Dashboard API v1",
  "scripts": {
    "build": "webpack --config webpack.config.js --mode production",
    "dev": "webpack --config webpack.config.js --mode development --watch",
    "test": "node --test tests/*.test.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --ext .ts,.tsx src",
    "server": "docker-compose up --build"
  },
  "devDependencies": {
    "@swc/core": "^1.4.17",
    "@types/node": "^26.1.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "style-loader": "^4.0.0",
    "swc-loader": "^0.2.6",
    "ts-node": "^10.9.2",
    "typescript": "^7.0.2",
    "webpack": "^5.91.0",
    "webpack-cli": "^7.2.1"
  },
  "dependencies": {
    "@grafana/data": "^13.1.1",
    "@grafana/runtime": "^13.1.0",
    "@grafana/schema": "^13.1.0",
    "@grafana/ui": "^13.1.0",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "overrides": {
    "dompurify": "3.4.12",
    "js-cookie": "3.0.8"
  }
}
