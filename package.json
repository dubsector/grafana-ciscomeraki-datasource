{
  "name": "dubsector-ciscomeraki-datasource",
  "version": "1.0.0",
  "description": "Grafana datasource plugin for Cisco Meraki Dashboard API v1",
  "scripts": {
    "build": "webpack --config webpack.config.js --mode production",
    "dev": "webpack --config webpack.config.js --mode development --watch",
    "test": "jest --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --ext .ts,.tsx src",
    "server": "docker-compose up --build"
  },
  "devDependencies": {
    "@swc/core": "^1.4.17",
    "@types/node": "^20.12.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.10.0",
    "style-loader": "^3.3.4",
    "swc-loader": "^0.2.6",
    "ts-node": "^10.9.2",
    "typescript": "^7.0.2",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@grafana/data": "^11.0.0",
    "@grafana/runtime": "^11.0.0",
    "@grafana/schema": "^11.0.0",
    "@grafana/ui": "^11.0.0",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  }
}
